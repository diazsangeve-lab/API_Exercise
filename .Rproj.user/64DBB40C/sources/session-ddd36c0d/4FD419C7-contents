    ## Fetching FRED data...

``` r
fetch <- function(id, start = "1982-01-01", end = "2025-07-01") {
  fredr(series_id = id,
        observation_start = as.Date(start),
        observation_end = as.Date(end)) %>%
    select(date, value) %>%
    rename(!!id := value)
}

gdp      <- fetch("GDPC1") #realGDP 
cons     <- fetch("PCECC96")  #realconsumption bc in model everything is already divided by PT
debt_nom <- fetch("GFDEBTN")  #nominal government debt   
deflator <- fetch("GDPDEF") #'officicial GDP deflator to be used as 'aggre price for nominal to real conversion'

#Converting monthly series into quarterly for consistency 

fetch_monthly_to_q <- function(id, start = "1982-01-01", end = "2025-07-01") {
  fredr(series_id = id,
        observation_start = as.Date(start),
        observation_end = as.Date(end)) %>%
    mutate(quarter = floor_date(date, "quarter")) %>%
    group_by(quarter) %>%
    summarise(!!id := mean(value, na.rm = TRUE)) %>%
    rename(date = quarter)
} #function for conversion

#conversion 
pop <- fetch_monthly_to_q("LFWA64TTUSM647S") #Civilian population as persons, using working age OECD/more closely aligned with SA labour rules for working age population
ffr <- fetch_monthly_to_q("FEDFUNDS")

# Merge all series

df <- gdp %>%
  inner_join(cons, by = "date") %>%
  inner_join(debt_nom, by = "date") %>%
  inner_join(deflator, by = "date") %>%
  inner_join(ffr, by = "date") %>%
  inner_join(pop, by = "date") %>%
  drop_na()

cat(sprintf("Sample: %d quarterly observations\n", nrow(df)))
```

    ## Sample: 175 quarterly observations

``` r
# Transformations

df <- df %>%
  mutate(
    # Per capita (GDP/cons in billions, pop already in persons => per person in dollars) 
    gdp_pc  = (GDPC1 * 1e9) / (LFWA64TTUSM647S),
    cons_pc = (PCECC96 * 1e9) / (LFWA64TTUSM647S),
    
    # Real debt: deflate nominal debt (millions) /  deflator ( conv. to get in percentage/decimal terms)
    debt_real = (GFDEBTN * 1e6) / (GDPDEF / 100),
    debt_pc   = debt_real / (LFWA64TTUSM647S), # real debt/ popn => real debt per capita
    
    # Log transform (per capita variables)
    ln_gdp  = log(gdp_pc),
    ln_cons = log(cons_pc),
    ln_debt = log(debt_pc),
    
    # Inflation rate (pi_t) => gross quarterly inflation: Pi_t = P_t / P_{t-1} using GDP Deflator instead of CPI 
    pi_gross = log(GDPDEF) / log(lag(GDPDEF)), 
    
    # Gross quarterly interest rate: 1 + FFR/400
    R_gross = 1 + FEDFUNDS / 400
  ) %>%
  drop_na()

#HP filter with lamda recomm from search for DSGE modelling = 1600

hp_gdp  <- hpfilter(df$ln_gdp,  freq = 1600)
hp_cons <- hpfilter(df$ln_cons, freq = 1600)
hp_debt <- hpfilter(df$ln_debt, freq = 1600)

df$gdp_cycle  <- hp_gdp$cycle
df$cons_cycle <- hp_cons$cycle
df$debt_cycle <- hp_debt$cycle

#Calculating the moments 

variables <- tibble(
  Variables = c("Output", "Household consumption", "Inflation (CPI)",
           "Public debt", "Federal funds rate"),
  col  = c("gdp_cycle", "cons_cycle", "pi_gross",
           "debt_cycle", "R_gross")
)

results <- variables %>%
  rowwise() %>%
  mutate(
    Standard_Deviation_pct = sd(df[[col]]) * 100,
    CorrelationwOutput = cor(df[[col]], df$gdp_cycle)
)


