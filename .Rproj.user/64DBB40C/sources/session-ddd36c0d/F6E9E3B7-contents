## Fetch Data

```{r fetch_data}
# South Africa unemployment rate (quarterly, %)
sa_unemp <- fredr(
  series_id        = "LRUN64TTZAQ156S",
  observation_start = as.Date("2000-01-01"),
  observation_end   = as.Date("2023-12-31")
) %>%
  mutate(country = "South Africa")

# Brazil unemployment rate (quarterly, %)
br_unemp <- fredr(
  series_id        = "LRUN64TTBRQ156S",
  observation_start = as.Date("2000-01-01"),
  observation_end   = as.Date("2023-12-31")
) %>%
  mutate(country = "Brazil")

# South Africa CPI inflation (year-on-year %)
sa_cpi <- fredr(
  series_id        = "ZAFCPIALLMINMEI",
  observation_start = as.Date("2000-01-01"),
  observation_end   = as.Date("2023-12-31")
)

# South Africa prime lending rate (%)
sa_rate <- fredr(
  series_id        = "INTPRIMNZAM193N",
  observation_start = as.Date("2000-01-01"),
  observation_end   = as.Date("2023-12-31")
)
```

---

## Clean & Reshape Data

```{r clean_data}
# --- Plot 1 data: combine SA and Brazil unemployment ---
unemp_combined <- bind_rows(sa_unemp, br_unemp) %>%
  select(date, value, country) %>%
  rename(unemployment_rate = value) %>%
  filter(!is.na(unemployment_rate))

# --- Plot 2 data: join CPI and lending rate for SA ---
monetary_policy <- sa_cpi %>%
  select(date, value) %>%
  rename(inflation = value) %>%
  inner_join(
    sa_rate %>% select(date, value) %>% rename(prime_rate = value),
    by = "date"
  ) %>%
  filter(!is.na(inflation), !is.na(prime_rate)) %>%
  pivot_longer(
    cols      = c(inflation, prime_rate),
    names_to  = "indicator",
    values_to = "value"
  ) %>%
  mutate(indicator = recode(indicator,
    "inflation"  = "CPI Inflation (%)",
    "prime_rate" = "Prime Lending Rate (%)"
  ))
```

