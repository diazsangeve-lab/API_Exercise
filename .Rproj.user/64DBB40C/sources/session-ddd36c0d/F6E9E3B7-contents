## Plot 1: Unemployment Rate — South Africa vs Brazil

```{r plot1, fig.width=10, fig.height=5}
p1 <- ggplot(unemp_combined, aes(x = date, y = unemployment_rate, colour = country)) +
  geom_line(linewidth = 0.9) +
  scale_colour_manual(values = c("South Africa" = "#0072B2", "Brazil" = "#D55E00")) +
  scale_y_continuous(labels = label_number(suffix = "%")) +
  scale_x_date(date_breaks = "3 years", date_labels = "%Y") +
  labs(
    title    = "Unemployment Rate: South Africa vs Brazil (2000–2023)",
    subtitle = "South Africa's unemployment rate has persistently exceeded Brazil's,\nhighlighting structural labour market challenges.",
    x        = NULL,
    y        = "Unemployment Rate (%)",
    colour   = NULL,
    caption  = "Source: FRED (ILO estimates)"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    legend.position  = "top",
    plot.title       = element_text(face = "bold"),
    plot.subtitle    = element_text(colour = "grey40"),
    panel.grid.minor = element_blank()
  )

p1
```

